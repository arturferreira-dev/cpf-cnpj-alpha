{
  "name": "cpf-cnpj-alpha",
  "version": "1.3.2",
  "description": "Format, validate, generate, anonymize and unmask CPF and CNPJ (including alphanumeric CNPJ) in TypeScript. Formatar, validar, gerar, anonimizar e remover máscara de CPF/CNPJ alfanumérico.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./v1": {
      "types": "./dist/v1/index.d.ts",
      "import": "./dist/v1/index.js",
      "require": "./dist/v1/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "build": "tsup src/index.ts src/v1/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "check": "bun test && bun run build",
    "prepublishOnly": "bun run check"
  },
  "author": "Artur Ferreira <arturferreira.dev>",
  "homepage": "https://github.com/arturferreira-dev/cpf-cnpj-alpha#readme",
  "bugs": {
    "url": "https://github.com/arturferreira-dev/cpf-cnpj-alpha/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arturferreira-dev/cpf-cnpj-alpha.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "cpf",
    "cnpj",
    "cpf-cnpj",
    "cpf cnpj",
    "cnpj alfanumerico",
    "cnpj alphanumeric",
    "format cpf",
    "format cnpj",
    "formatar cpf",
    "formatar cnpj",
    "formatter",
    "formatador",
    "validate cpf",
    "validate cnpj",
    "validar cpf",
    "validar cnpj",
    "validacao",
    "validation",
    "generate cpf",
    "generate cnpj",
    "gerar cpf",
    "gerar cnpj",
    "anonymize",
    "anonimizar",
    "mask",
    "unmask",
    "mascara",
    "documento",
    "receita federal",
    "brazil",
    "brasil",
    "typescript",
    "bun",
    "node",
    "esm",
    "cjs",
    "utils",
    "util"
  ],
  "license": "MIT"
}
