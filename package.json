{
  "name": "cpf-cnpj-alpha",
  "version": "1.3.0",
  "description": "Formatadores de CPF/CNPJ em TypeScript com suporte a CNPJ alfanumérico.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./v1": {
      "types": "./dist/v1/index.d.ts",
      "import": "./dist/v1/index.js",
      "require": "./dist/v1/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "build": "tsup src/index.ts src/v1/index.ts --format esm,cjs --dts --out-dir dist --clean",
    "check": "bun test && bun run build",
    "prepublishOnly": "bun run check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arturferreira-dev/cpf-cnpj-alpha.git"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  },
  "keywords": [
    "cpf",
    "cnpj",
    "cnpj alfanumérico",
    "cpf cnpj",
    "formatter",
    "formatador",
    "validacao",
    "validação",
    "anonymize",
    "anonimizacao",
    "anonimização",
    "documento brasileiro",
    "typescript",
    "bun",
    "npm",
    "brasil"
  ],
  "license": "MIT"
}
